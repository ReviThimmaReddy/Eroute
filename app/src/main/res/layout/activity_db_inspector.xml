<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".DbInspectorActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. Header Area -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:background="#020617"
                android:paddingHorizontal="20dp">

                <FrameLayout
                    android:id="@+id/logoIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_pill_dark"
                    android:backgroundTint="#0F172A"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_bus"
                        android:contentDescription="@null"
                        app:tint="@color/white" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/logoIcon"
                    app:layout_constraintTop_toTopOf="parent">
                    <TextView
                        android:id="@+id/headerUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/brand_name"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/headerUserRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SMART STUDENT MOBILITY SYSTEM"
                        android:textColor="#94A3B8"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <TextView
                    android:id="@+id/profileInitial"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_pill_dark"
                    android:backgroundTint="#F59E0B"
                    android:gravity="center"
                    android:text="DB"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnLogout"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLogout"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_button_dark"
                    android:backgroundTint="#0F172A"
                    android:paddingHorizontal="16dp"
                    android:text="@string/logout"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 2. Gate Control Menu (Integrated) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="@string/menu_title"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <LinearLayout
                    android:id="@+id/menuDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_dashboard" app:tint="#64748B" android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:text="@string/menu_dashboard" android:textColor="#94A3B8" android:textSize="14sp" />
                </LinearLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/menuNotifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:padding="14dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView android:id="@+id/ivNotif" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_popup_reminder" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:tint="#64748B" android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:text="@string/menu_notifications" android:textColor="#94A3B8" android:textSize="14sp" app:layout_constraintStart_toEndOf="@id/ivNotif" app:layout_constraintTop_toTopOf="parent" />
                    <TextView android:layout_width="16dp" android:layout_height="16dp" android:background="@drawable/bg_pill_dark" android:backgroundTint="#991B1B" android:gravity="center" android:text="1" android:textColor="@color/white" android:textSize="9sp" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:id="@+id/menuProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="#64748B" android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:text="@string/menu_profile" android:textColor="#94A3B8" android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menuInspector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_pill_dark"
                    android:backgroundTint="#0F172A"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_database" app:tint="@color/white" android:alpha="0.7" android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:text="@string/menu_inspector" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="20dp" android:background="#1E293B" />

            <!-- 3. DB Inspector Section Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/db_inspector_live_title"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/db_inspector_live_subtitle"
                    android:textColor="#64748B"
                    android:textSize="14sp" />

                <!-- Server Simulator Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_role_card"
                    android:backgroundTint="#0F172A"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                         <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_database" app:tint="#F59E0B" android:contentDescription="@null" />
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="@string/db_server_simulator_title" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                         <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_pill_dark" android:backgroundTint="#064E3B" android:paddingHorizontal="10dp" android:paddingVertical="2dp" android:text="● ONLINE" android:textColor="#10B981" android:textSize="9sp" android:textStyle="bold" />
                    </LinearLayout>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/db_server_simulator_desc" android:textColor="#94A3B8" android:textSize="12sp" android:lineSpacingExtra="4dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_button_dark"
                        android:backgroundTint="#1E293B"
                        android:text="@string/btn_refresh_tables"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Metrics Grid -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:columnCount="2">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="6dp" android:background="@drawable/bg_role_card" android:backgroundTint="#0F172A" android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="tbl_users" android:textColor="#64748B" android:textSize="10sp" android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvUserRows"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="0 Rows"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="6dp" android:background="@drawable/bg_role_card" android:backgroundTint="#0F172A" android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="tbl_students" android:textColor="#64748B" android:textSize="10sp" android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvPassRows"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="0 Rows"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </GridLayout>

                <!-- Data Table Mockup -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_role_card"
                    android:backgroundTint="#0F172A"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TABLE: bus_passes" android:textColor="#94A3B8" android:textSize="10sp" android:textStyle="bold" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="16dp" android:background="#1E293B" />

                    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content">
                         <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                              <!-- Header Row -->
                              <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp">
                                   <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="ID" android:textColor="#64748B" android:textSize="10sp" android:textStyle="bold" />
                                   <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="STUDENT" android:textColor="#64748B" android:textSize="10sp" android:textStyle="bold" />
                                   <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="ROUTE" android:textColor="#64748B" android:textSize="10sp" android:textStyle="bold" />
                              </LinearLayout>
                              <!-- Data Row -->
                              <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="12dp">
                                   <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="PASS808" android:textColor="@color/white" android:textSize="11sp" />
                                   <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Amelia Chen" android:textColor="@color/white" android:textSize="11sp" />
                                   <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Route 202" android:textColor="@color/white" android:textSize="11sp" />
                              </LinearLayout>
                         </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>

                <!-- Console Console -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="40dp"
                    android:background="#020617"
                    android:orientation="vertical"
                    android:padding="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SQL LEDGER CONSOLE" android:textColor="#F59E0B" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="SELECT * FROM `bus_passes` ORDER BY `id` DESC;" android:textColor="#10B981" android:textSize="12sp" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="200 OK: Fetched 4 rows from SQL Ledger" android:textColor="#64748B" android:textSize="10sp" android:fontFamily="monospace" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar (Mockup) -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#020617"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_today" app:tint="#64748B" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textColor="#64748B" android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_gallery" app:tint="#64748B" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data" android:textColor="#64748B" android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/bg_pill_dark" android:backgroundTint="#1E293B" android:gravity="center" android:text="1" android:textColor="#94A3B8" android:textSize="10sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Console" android:textColor="#64748B" android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_database" app:tint="@color/white" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tables" android:textColor="@color/white" android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>